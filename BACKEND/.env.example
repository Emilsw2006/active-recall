# Active Recall — Variables de entorno
# Copia este archivo a .env y rellena los valores reales
# NUNCA subas .env a GitHub

# Google Cloud / Gemini
GOOGLE_CLOUD_PROJECT=tu-proyecto-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash

# Groq (LLM para evaluación — gratis con límite generoso)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxx

# Seguridad JWT
SECRET_KEY=genera_uno_largo_aqui

# TTS — Kokoro (local, open source, recomendado en Oracle ARM)
USE_KOKORO_TTS=true
KOKORO_VOICE=ef_dora

# TTS — Piper (local, neural, sin internet)
USE_PIPER_TTS=false

# TTS — Azure (opcional, 5M chars/mes gratis)
AZURE_TTS_KEY=
AZURE_TTS_REGION=eastus
AZURE_TTS_VOICE=es-ES-ElviraNeural

# TTS — ElevenLabs (opcional, 10k chars/mes gratis)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# TTS — OpenAI (opcional, de pago)
OPENAI_API_KEY=
