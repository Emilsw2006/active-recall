# ⚙️ Environment Variables — Active Recall Frontend

# Copiar a .env en la raíz de WEB/ y EXPO/
# Reemplazar valores marcados con XXX

# ════════════════════════════════════════════════════════════════
# 🔌 BACKEND CONNECTION
# ════════════════════════════════════════════════════════════════

# URL base del backend FastAPI (SIN trailing slash)
# Desarrollo local:  http://localhost:8000
# Producción:        https://api.tudominio.com
VITE_API_BASE_URL=https://api.tudominio.com

# WebSocket URL para sesiones de voz (con wss para HTTPS, ws para HTTP)
# Desarrollo local:  ws://localhost:8000
# Producción:        wss://api.tudominio.com
VITE_WS_BASE_URL=wss://api.tudominio.com

# ════════════════════════════════════════════════════════════════
# 🔐 AUTHENTICATION (Google OAuth)
# ════════════════════════════════════════════════════════════════

# Google OAuth Client ID
# Obtener de: https://console.cloud.google.com
# Authorized JavaScript origins debe incluir:
#   - http://localhost:5173 (dev web)
#   - http://localhost:8081 (dev Expo)
#   - https://tudominio.com (producción)
VITE_GOOGLE_CLIENT_ID=XXX-XXX.apps.googleusercontent.com

# ════════════════════════════════════════════════════════════════
# 🗄️ SUPABASE (Opcional, si acceso directo)
# ════════════════════════════════════════════════════════════════

# URL de tu proyecto Supabase
# Ej: https://xyzabc.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (visible, es segura para cliente)
VITE_SUPABASE_KEY=your-anon-key-here

# ════════════════════════════════════════════════════════════════
# 📊 ANALYTICS (Opcional)
# ════════════════════════════════════════════════════════════════

# Google Analytics ID (si lo usas)
# Ej: G-XXXXXXXXXX
VITE_ANALYTICS_ID=

# ════════════════════════════════════════════════════════════════
# 🔧 ENVIRONMENT & DEBUG
# ════════════════════════════════════════════════════════════════

# development | production | staging
NODE_ENV=development

# true para verbose logs en consola
VITE_DEBUG_MODE=false

# ════════════════════════════════════════════════════════════════
# 🚀 CONFIGURACIÓN POR AMBIENTE
# ════════════════════════════════════════════════════════════════

# === DESARROLLO LOCAL (PC) ===
# VITE_API_BASE_URL=http://localhost:8000
# VITE_WS_BASE_URL=ws://localhost:8000
# NODE_ENV=development

# === DESARROLLO LOCAL (Móvil con Expo) ===
# Necesitas IP local del PC donde corre el backend
# VITE_API_BASE_URL=http://192.168.x.x:8000    # Reemplaza con tu IP
# VITE_WS_BASE_URL=ws://192.168.x.x:8000

# === STAGING ===
# VITE_API_BASE_URL=https://staging-api.tudominio.com
# VITE_WS_BASE_URL=wss://staging-api.tudominio.com
# NODE_ENV=staging

# === PRODUCCIÓN ===
# VITE_API_BASE_URL=https://api.tudominio.com
# VITE_WS_BASE_URL=wss://api.tudominio.com
# NODE_ENV=production

# ════════════════════════════════════════════════════════════════
# ℹ️ NOTAS IMPORTANTES
# ════════════════════════════════════════════════════════════════

# 1. NUNCA commiteador .env real a git (solo .env.example)
#    .gitignore debe incluir: .env, .env.local
#
# 2. Cada proyecto (WEB, EXPO) necesita su propio .env
#    Copiar este archivo a WEB/ y EXPO/ root
#
# 3. Google OAuth:
#    - Crear credential type "OAuth 2.0 Client ID" en Google Cloud
#    - Application type: Web application (WEB) o Android/iOS (EXPO)
#    - Agregar URIs autorizados (localhost dev + dominio prod)
#    - Copiar Client ID a VITE_GOOGLE_CLIENT_ID
#
# 4. Backend CORS:
#    Verificar que main.py permite tu origen:
#    CORSMiddleware(app, allow_origins=["http://localhost:5173", "https://tudominio.com"])
#
# 5. Variables VITE_* son expuestas en el cliente (OK para URLs públicas)
#    Secretos (API keys privadas) NO deben ir aquí
#
# 6. WebSocket:
#    - ws:// para HTTP local
#    - wss:// para HTTPS producción
#    - Backend debe soportar conexiones persistentes
#
# 7. Cambios en .env requieren reiniciar servidor dev:
#    WEB: Ctrl+C y `npm run dev`
#    EXPO: Presionar Ctrl+C y `npx expo start`
